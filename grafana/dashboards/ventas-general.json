        {
          "dataset": "AdventureWorksDW2022",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\r\n    CASE Pais\r\n        WHEN 'United States'  THEN 'USA'\r\n        WHEN 'Australia'      THEN 'AUS'\r\n        WHEN 'United Kingdom' THEN 'GBR'\r\n        WHEN 'Germany'        THEN 'DEU'\r\n        WHEN 'France'         THEN 'FRA'\r\n        WHEN 'Canada'         THEN 'CAN'\r\n        ELSE NULL\r\n    END AS lookup,\r\n    GrupoTerritorial,\r\n    Pais,\r\n    TotalVentas\r\nFROM dbo.vw_BI_VentasPorTerritorioGrupo\r\nWHERE CASE Pais\r\n        WHEN 'United States'  THEN 'USA'\r\n        WHEN 'Australia'      THEN 'AUS'\r\n        WHEN 'United Kingdom' THEN 'GBR'\r\n        WHEN 'Germany'        THEN 'DEU'\r\n        WHEN 'France'         THEN 'FRA'\r\n        WHEN 'Canada'         THEN 'CAN'\r\n        ELSE NULL\r\n      END IS NOT NULL\r\nORDER BY TotalVentas DESC;",
          "refId": "A",
          "sql": {
